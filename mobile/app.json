{
  "expo": {
    "name": "BAIO",
    "slug": "baio-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "baio",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#E7E1D4"
    },
    "ios": {
      "bundleIdentifier": "io.bowlingalleys.mobile",
      "supportsTablet": true
    },
    "android": {
      "package": "io.bowlingalleys.mobile",
      "config": {
        "googleMaps": {
          "apiKey": "ADD_YOUR_GOOGLE_MAPS_API_KEY"
        }
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "We use your location to find bowling alleys near you."
        }
      ]
    ]
  }
}
