# Google Analytics 4
# Find this in GA4 Admin > Property > Property Details
GA4_PROPERTY_ID=123456789

# Google Search Console
# Your verified site URL (include protocol)
GSC_SITE_URL=https://bowlingalleys.io

# Path to the dedicated analytics service account JSON key
# Create a new service account in GCP Console with:
#   - GA4: Viewer role (added in GA4 Admin > Property Access Management)
#   - GSC: Restricted permission (added in GSC > Settings > Users)
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
